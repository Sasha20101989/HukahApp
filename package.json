{
  "name": "hookah-platform",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "frontend/crm-app",
    "frontend/client-app"
  ],
  "scripts": {
    "local:up": "bash scripts/local-up.sh",
    "local:up:nobuild": "bash scripts/local-up.sh --no-build",
    "local:up:nocache": "bash scripts/local-up.sh --no-cache",
    "local:up:logs": "bash scripts/local-up.sh --logs",
    "local:reset": "bash scripts/local-up.sh --reset",
    "local:down": "bash scripts/local-down.sh",
    "local:down:volumes": "bash scripts/local-down.sh --volumes",
    "crm:dev": "corepack pnpm --dir frontend/crm-app dev",
    "client:dev": "corepack pnpm --dir frontend/client-app dev",
    "frontend:lint": "corepack pnpm --dir frontend/crm-app lint && corepack pnpm --dir frontend/client-app lint",
    "frontend:build": "corepack pnpm --dir frontend/crm-app build && corepack pnpm --dir frontend/client-app build",
    "frontend:smoke": "node scripts/frontend-smoke.mjs",
    "frontend:browser-smoke": "node scripts/browser-smoke.mjs",
    "api:crud-smoke": "node scripts/api-crud-smoke.mjs",
    "tenant:isolation-smoke": "node scripts/tenant-isolation-smoke.mjs"
  }
}
