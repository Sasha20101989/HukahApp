@gateway = http://localhost:8080
@clientToken = replace-with-client-access-token
@ownerToken = replace-with-owner-access-token
@clientId = replace-with-client-id
@branchId = replace-with-branch-id
@tableId = replace-with-table-id
@hookahId = replace-with-hookah-id
@bowlId = replace-with-bowl-id
@mixId = replace-with-mix-id
@tobaccoId1 = replace-with-tobacco-id-1
@tobaccoId2 = replace-with-tobacco-id-2

### Gateway catalog
GET {{gateway}}/api/catalog/services

### Register client
POST {{gateway}}/api/auth/register
Content-Type: application/json

{
  "name": "Alexander",
  "phone": "+79990000001",
  "email": "client@hookah.local",
  "password": "password"
}

### Login client
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "phone": "+79990000001",
  "password": "password"
}

### Login owner
POST {{gateway}}/api/auth/login
Content-Type: application/json

{
  "phone": "+79990000000",
  "password": "password"
}

### Branch floor plan
GET {{gateway}}/api/branches/{{branchId}}/floor-plan

### Staff shifts
GET {{gateway}}/api/staff/shifts?branchId={{branchId}}&from=2026-05-01&to=2026-05-02

### Roles
GET {{gateway}}/api/roles

### Permissions
GET {{gateway}}/api/permissions

### Client booking eligibility
GET {{gateway}}/api/users/{{clientId}}/booking-eligibility

### Client permissions
GET {{gateway}}/api/users/{{clientId}}/permissions

### Calculate mix grams
POST {{gateway}}/api/mixes/calculate
Content-Type: application/json

{
  "bowlId": "{{bowlId}}",
  "items": [
    { "tobaccoId": "{{tobaccoId1}}", "percent": 50 },
    { "tobaccoId": "{{tobaccoId2}}", "percent": 50 }
  ]
}

### Check booking availability
GET {{gateway}}/api/bookings/availability?branchId={{branchId}}&date=2026-05-01&time=20:00&guestsCount=4

### Check inventory for a mix
POST {{gateway}}/api/inventory/check
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "branchId": "{{branchId}}",
  "items": [
    { "tobaccoId": "{{tobaccoId1}}", "requiredGrams": 7.2 },
    { "tobaccoId": "{{tobaccoId2}}", "requiredGrams": 5.4 }
  ]
}

### Public mix list without internal cost
GET {{gateway}}/api/mixes?publicOnly=true&availableOnly=true&branchId={{branchId}}

### Validate promo
POST {{gateway}}/api/promocodes/validate
Content-Type: application/json

{
  "code": "HOOKAH20",
  "clientId": "{{clientId}}",
  "orderAmount": 3000
}

### Review summary
GET {{gateway}}/api/reviews/mixes/{{mixId}}/summary

### Analytics dashboard
GET {{gateway}}/api/analytics/dashboard?branchId={{branchId}}&from=2026-04-01&to=2026-04-30

### Notification templates
GET {{gateway}}/api/notifications/templates

### Order status flow
GET {{gateway}}/api/orders/status-flow

### Create order
POST {{gateway}}/api/orders
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "branchId": "{{branchId}}",
  "tableId": "{{tableId}}",
  "clientId": "{{clientId}}",
  "hookahId": "{{hookahId}}",
  "bowlId": "{{bowlId}}",
  "mixId": "{{mixId}}",
  "waiterId": null,
  "bookingId": null,
  "price": 850,
  "comment": "Medium strength"
}

### Move order to preparing
PATCH {{gateway}}/api/orders/replace-with-order-id/status
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "status": "PREPARING"
}

### Serve order and write off inventory once
PATCH {{gateway}}/api/orders/replace-with-order-id/status
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "status": "SERVED"
}

### Create deposit booking
POST {{gateway}}/api/bookings
Content-Type: application/json
Authorization: Bearer {{clientToken}}

{
  "branchId": "{{branchId}}",
  "tableId": "{{tableId}}",
  "clientId": "{{clientId}}",
  "startTime": "2026-05-01T20:00:00Z",
  "endTime": "2026-05-01T22:00:00Z",
  "guestsCount": 4,
  "hookahId": "{{hookahId}}",
  "bowlId": "{{bowlId}}",
  "mixId": "{{mixId}}",
  "comment": "Birthday",
  "depositAmount": 2000
}

### Create payment
POST {{gateway}}/api/payments/create
Content-Type: application/json
Authorization: Bearer {{clientToken}}

{
  "clientId": "{{clientId}}",
  "bookingId": "replace-with-booking-id",
  "amount": 2000,
  "currency": "RUB",
  "type": "DEPOSIT",
  "provider": "YOOKASSA",
  "promocode": "HOOKAH20"
}

### YooKassa webhook
POST {{gateway}}/api/payments/webhook/yookassa
Content-Type: application/json
X-Webhook-Secret: local-yookassa-webhook-secret

{
  "paymentId": "replace-with-payment-id",
  "externalPaymentId": "yk-test-1",
  "succeeded": true
}

### Refund payment
POST {{gateway}}/api/payments/replace-with-payment-id/refund
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "amount": 500,
  "reason": "Partial refund"
}

### Read table
GET {{gateway}}/api/tables/{{tableId}}

### Read hookah
GET {{gateway}}/api/hookahs/{{hookahId}}
